@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    var payPalClientId = Configuration["PayPal:ClientId"];
    const string fallbackPayPalClientId = "ATxIpjOz21H4-4sWp6YRU9f8OHXmMVT-p0rg9kd_dVtgDFYyQZaG5GlFZ9Q-xxGDyY16nOS3R4W-PY4M";

    if (string.IsNullOrWhiteSpace(payPalClientId) ||
        payPalClientId.StartsWith("YOUR_", System.StringComparison.OrdinalIgnoreCase))
    {
        payPalClientId = fallbackPayPalClientId;
    }
}

<div class="wshipping-content-block wshipping-breadcroumb inner-bg-1 payment-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-lg-7">
                <span class="shipment-page-kicker">Secure checkout</span>
                <h1>Payment</h1>
                <div class="shipment-breadcrumb">
                    <a asp-controller="Home" asp-action="Index" title="Home">@Lables.Home</a> / Payment
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="shipment-hero-note">
                    <i class="fa fa-credit-card"></i>
                    <h4>Complete a test payment before attaching it to a shipment.</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="wshipping-content-block shipping-block payment-page">
    <div class="container">
        <div class="payment-page-head">
            <span>Checkout</span>
            <h2>Complete payment</h2>
        </div>

        <div class="row">
            <div class="col-12 col-lg-5">
                <div class="shipping-form-block payment-card payment-summary-card">
                    <h3 class="mb-3">Order summary</h3>
                    <div class="shipping-form">
                        <div class="form-group">
                            <label>Item</label>
                            <input type="text" id="PaymentItemName" class="form-control" value="Shipping Service" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <input type="text" id="PaymentItemDescription" class="form-control" value="Temporary shipment payment" />
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <div class="form-group">
                                    <label>Amount</label>
                                    <input type="number" id="PaymentAmount" class="form-control" min="1" step="0.01" value="25.00" />
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-group">
                                    <label>Quantity</label>
                                    <input type="number" id="PaymentQuantity" class="form-control" min="1" step="1" value="1" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-7">
                <div class="shipping-form-block payment-card payment-checkout-card">
                    <h3 class="mb-3">Pay with PayPal</h3>
                    <p class="payment-card-note">Use the sandbox checkout to verify the payment flow.</p>
                    <div id="paypal-button-container"></div>
                    <p id="paypal-result-message" class="mt-3"></p>
                    <pre id="paypal-debug-output" class="mt-3 p-3 bg-light" style="display:none; white-space:pre-wrap;"></pre>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/Modules/AppHelper.js"></script>
    <script src="~/Modules/ApiClient.js"></script>
    <script>
        window.paymentTestData = {
            currency: "USD"
        };
    </script>
    <script
        src="https://www.paypal.com/sdk/js?client-id=@payPalClientId&currency=USD&components=buttons&enable-funding=paylater,card"
        data-sdk-integration-source="shipping-system-payment-test"></script>
    <script src="~/Modules/payment-test.js" asp-append-version="true"></script>
}
