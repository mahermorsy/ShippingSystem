
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isHome = currentController == "Home" && currentAction == "Index";
    var isAbout = currentController == "Home" && currentAction == "About";
    var isServices = currentController == "Home" && currentAction == "OurServices";
    var isShipping = currentController == "Shipments" && currentAction == "CreateShipment";
    var isShipmentList = currentController == "Shipments" && currentAction == "List";
    var isPayment = currentController == "Home" && currentAction == "Payment";
    var isBlog = currentController == "Home" && currentAction == "Blog";
    var isContact = currentController == "Home" && currentAction == "Contact";
}

<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8">
    <meta name="description" content="">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="keywords" content="Bootstrap4, Multipurpose, responsive, Business, template,Shipping, Cargo, logistic, html5, css, javascript, web24service" />
    <meta name="author" content="web24service">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Title -->
    <title>W Shipping</title>

    <!-- Favicon -->
    <link rel="shortcut icon" type="image/png" href="~/assets/images/fevicon.png">
    <!-- Bootstrap LTR CSS -->
    <link rel="stylesheet" href="~/assets/css/bootstrap.min.css">
    <!-- Font awesome CSS -->
    <link rel="stylesheet" href="~/assets/css/fontawesome.all.min.css">
    <!-- Animate CSS -->
    <link rel="stylesheet" href="~/assets/css/animate.min.css">
    <!-- OwlCarousel CSS -->
    <link rel="stylesheet" href="~/assets/css/owl.carousel.min.css">
    <!-- Magnific popup CSS -->
    <link rel="stylesheet" href="~/assets/css/fancybox.min.css">
    <!-- chat CSS -->
    <link rel="stylesheet" href="~/assets/css/chat.css">
    <!-- Slicknav CSS -->
    <link rel="stylesheet" href="~/assets/css/slicknav.min.css">
    <!-- Date picker CSS -->
    <link rel="stylesheet" href="~/assets/css/bootstrap-datetimepicker.min.css">
    <!-- Main CSS -->
    <link rel="stylesheet" href="~/assets/css/style.css">
    <!-- Responsive CSS -->
    <link rel="stylesheet" href="~/assets/css/responsive.css">
    <link rel="stylesheet" href="~/assets/css/public-overrides.css" asp-append-version="true">
    <!-- RTL CSS -->
    <!-- <link rel="stylesheet" href="~/assets/css/rtl.css"> -->
    <!-- jQuery -->
    <script src="~/assets/js/jquery-3.4.1.min.js"></script>
    <!-- RTL CSS -->
    <!-- <link rel="stylesheet" href="assets/css/rtl.css"> -->

</head>
<body>
    <!-- Main Wrapper Start -->
    <div class="main-wrapper">
  
        <!-- skiptocontent start ( This section for blind and Google SEO, Also for page speed )-->
        <a id="skiptocontent" href="#maincontent">skip navigation</a>
        <!-- skiptocontent End -->
        <!-- Preloader start -->
        <div class="wshipping-site-preloader-wrapper">
            <div class="spinner">
                <div class="double-bounce1"></div>
                <div class="double-bounce2"></div>
            </div>
        </div>
        <!-- Preloader End -->
  
        <header class="for-sticky">
            <!-- Header top area start -->
            <div class="header-top-area">
                <div class="container">
                    <div class="row">
                        <div class="col-12 col-lg-8">
                            <div class="top-contact"> <a href="#"><i class="fa fa-envelope"></i> info@company.com</a> <a href="#"><i class="fa fa-phone"></i> +966 548194848</a> <a href="#"><i class="far fa-clock"></i> 9:00AM to 8:00PM</a> </div>
                        </div>
                        <div class="col-12 col-lg-4 d-flex justify-content-center justify-content-lg-end">
                            <div class="top-menu">
                                <ul>
                                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <li>
                                            <a asp-controller="Account" asp-action="Logout">
                                                <i class="fas fa-sign-out-alt"></i> Logout
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <a asp-controller="Account" asp-action="Login">
                                                <i class="fas fa-sign-in-alt"></i> @Lables.Login
                                            </a>
                                        </li>

                                        <li>
                                            <a asp-controller="Account" asp-action="Register">
                                                <i class="fa fa-unlock-alt"></i> @Lables.Registration
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>  
                            <div class="language">
                                <ul>
                                    <li>
                                        <a href="#" title="" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false"><img src="~/assets/images/flag-1.png" alt="" /> EN</a>
                                        <ul class="dropdown-menu">
                                            <li><a href="" title=""><img src="~/assets/images/flag-1.png" alt="" /> EN</a></li>
                                            <li><a href="" title=""><img src="~/assets/images/flag-2.png" alt="" /> TR</a></li>
                                            <li><a href="" title=""><img src="~/assets/images/flag-3.png" alt="" /> BR</a></li>
                                            <li><a href="" title=""><img src="~/assets/images/flag-4.png" alt="" /> SR</a></li>
                                        </ul>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Header top area End -->
            <!-- Header area start -->
            <div class="header-area">
                <div class="container">
                    <!-- Site logo Start -->
                    <div class="logo"> <a asp-controller="Home" asp-action="Index" title="W-shipping"><img src="~/assets/images/logo.png" alt="W-shipping" /></a> </div>
                    <!-- Site logo end -->
                    <div class="mobile-menu-wrapper"></div>
                    <!-- Main menu start -->
                    <nav class="mainmenu">
                        <ul id="navigation">

                            <li class="@(isHome ? "nav-active" : "")">
                                <a asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="@(isAbout ? "nav-active" : "")"><a asp-controller="Home" asp-action="About">About Us</a></li>
                            <li class="@(isServices ? "nav-active" : "")"><a asp-controller="Home" asp-action="OurServices">Services</a></li>
                            <li class="@(isShipping ? "nav-active" : "")"><a asp-controller="Shipments" asp-action="CreateShipment">Shipping</a></li>
                            <li class="@(isPayment ? "nav-active" : "")"><a asp-controller="Home" asp-action="Payment">Payment</a></li>
                            <li class="@(isBlog ? "nav-active" : "")"><a asp-controller="Home" asp-action="Blog">Blog</a></li>
                            <li class="@(isContact ? "nav-active" : "")"><a asp-controller="Home" asp-action="Contact">Contact Us</a></li>
                            <li class="@(isShipmentList ? "nav-active" : "")"><a asp-controller="Shipments" asp-action="List">Shipments History</a></li>

                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle d-flex align-items-center"
                                           href="#"
                                           id="userDropdown"
                                           data-toggle="dropdown">

                                        <img class="header-profile-pic rounded-circle"
                                             src="~/assets/images/profile.jpg"
                                             width="35" height="35" />

                                        <span class="ml-2">@User.Identity.Name</span>
                                    </a>

                                    <div class="dropdown-menu dropdown-menu-right">

                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fa fa-user"></i> Profile
                                        </a>

                                        <a class="dropdown-item" asp-controller="Account" asp-action="Settings">
                                            <i class="fa fa-cog"></i> Settings
                                        </a>

                                        <div class="dropdown-divider"></div>

                                        <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                            <i class="fa fa-sign-out-alt"></i> Logout
                                        </a>

                                    </div>
                                </li>
                            }

                        </ul>
                    </nav>
                    <!-- Main menu end -->
                </div>
            </div>
            <!-- Header area End -->
        </header>
  
        <!-- Slider Start -->
        @RenderBody()
        <!-- Footer start -->
        <footer class="site-footer">
            <!-- Footer Top start -->
            <div class="footer-top-area">
                <div class="container">
                    <div class="row">
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="footer-wiz footer-brand-card">
                                <h3 class="footer-logo"><img src="~/assets/images/footer-logo.png" alt="footer logo" /></h3>
                                <p>Reliable shipment management for customers, carriers, and operations teams.</p>
                                <ul class="footer-contact">
                                    <li><i class="fa fa-phone"></i> +966 548194848</li>
                                    <li><i class="fa fa-envelope"></i> info@company.com</li>
                                    <li><i class="fa fa-clock"></i> 9:00AM to 8:00PM</li>
                                </ul>
                            </div>
                            <div class="top-social bottom-social"> <a href="#"><i class="fab fa-facebook-f"></i></a> <a href="#"><i class="fab fa-twitter"></i></a> <a href="#"><i class="fab fa-youtube"></i></a> <a href="#"><i class="fa fa-rss"></i></a> </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="footer-wiz footer-menu">
                                <h3 class="footer-wiz-title">Quick Links</h3>
                                <ul>
                                    <li><a asp-controller="Home" asp-action="About">Company Overview</a></li>
                                    <li><a asp-controller="Home" asp-action="OurServices">Our Services</a></li>
                                    <li><a asp-controller="Home" asp-action="Blog">Blog</a></li>
                                    <li><a asp-controller="Home" asp-action="Contact">Contact Us</a></li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="footer-wiz footer-menu">
                                <h3 class="footer-wiz-title">Useful Links</h3>
                                <ul>
                                    <li><a asp-controller="Shipments" asp-action="CreateShipment">Create Shipment</a></li>
                                    <li><a asp-controller="Shipments" asp-action="List">Shipment History</a></li>
                                    <li><a asp-controller="Home" asp-action="Payment">Payment</a></li>
                                    <li><a asp-controller="Account" asp-action="Login">Customer Login</a></li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="footer-wiz">
                                <h3 class="footer-wiz-title">Opening Hours</h3>
                                <ul class="open-hours">
                                    <li><span>Mon to Fri:</span> <span class="text-right">09:00AM to 8:00PM</span></li>
                                    <li><span>Saturday:</span> <span class="text-right">10:00AM to 4:00PM</span></li>
                                    <li><span>Sunday:</span> <span class="text-right">Closed</span></li>
                                </ul>
                                <div class="footer-cta">
                                    <span>Need to send a package?</span>
                                    <a asp-controller="Shipments" asp-action="CreateShipment">Start Shipment</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- footer top end -->
            <!-- copyright start -->
            <div class="footer-bottom-area">
                <div class="container">
                    <div class="row">
                        <div class="col-12 col-lg-6 wow fadeInLeft">Copyright © 2026 <span>W Shipping</span>. All Rights Reserved</div>
                        <div class="col-12 col-lg-6 text-right wow fadeInRight">Shipment operations made simple</div>
                    </div>
                </div>
            </div>
            <!-- copyright end -->
        </footer>
        <!-- Footer end -->
    </div>
    <!-- Main Wrapper end -->
    <!-- Start scroll top -->
    <div class="scrollup"><i class="fas fa-chevron-up"></i></div>
    <!-- End scroll top -->
    <!-- Tether JS -->
    <script src="~/assets/js/tether.min.js"></script>

    <!-- Popper JS -->
    <script src="~/assets/js/popper.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="~/assets/js/bootstrap.min.js"></script>

    <!-- OwlCarousel JS -->
    <script src="~/assets/js/owl.carousel.min.js"></script>

    <!-- Bootstrap dateTimePicker -->
    <script src="~/assets/js/datetimepicker-moment.min.js"></script>
    <script src="~/assets/js/bootstrap-datetimepicker.min.js"></script>

    <!-- SlickNav JS -->
    <script src="~/assets/js/jquery.slicknav.min.js"></script>

    <!-- fancybox Popup JS -->
    <script src="~/assets/js/jquery.fancybox.min.js"></script>

    <!-- WOW JS -->
    <script src="~/assets/js/wow-1.3.0.min.js"></script>

    <!-- Step Form with validate -->
    <script src="~/assets/js/jquery.validate.js"></script>
    <script src="~/assets/js/form-step.js"></script>

    <!-- SlickNav JS -->
    <script src="~/assets/js/youtube-background.js"></script>

    <!-- Gallery Filter -->
    <script src="~/assets/js/jquery.filterizr.min.js"></script>

    <!-- Chat JS -->
    <script src="~/assets/js/chat.js"></script>

    <!-- Coming Soon JS -->
    <script src="~/assets/js/coming-soon.js"></script>

    <!-- Active JS -->
    <script src="~/assets/js/active.js" asp-append-version="true"></script>
    <script>
        window.appConfig = {
            apiBaseUrl: '@(Configuration["AuthApi:BaseUrl"]?.TrimEnd('/'))'
        };
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
