@model List<DtoShipment>
<!-- Breadcroumbs start -->
<div class="wshipping-content-block wshipping-breadcroumb inner-bg-1">
    <div class="container">
        <div class="row">
            <div class="col-12 col-lg-7">
                <h1>Shipment History</h1>
                <a asp-controller="Home" asp-action="Index" title="Home">Home</a> / Shipment History
            </div>
            <div class="col-12 col-lg-5 text-right">
                <h4>
                    We freight to all over the world
                    The best logistic company, <span>FAST</span> and <span>SAFELY!</span>
                </h4>
            </div>
        </div>
    </div>
</div>
<!-- Breadcroumbs end -->

<!-- Shipment History start -->
<div class="wshipping-content-block">
    <div class="container">
        <div class="row">
            <div class="col-12 col-lg-9">
                <div class="order-list">
                    <h3>Your Shipment History</h3>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover text-center align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Tracking</th>
                                    <th>Shipping Date</th>
                                    <th>Delivery Date</th>
                                    <th>Sender</th>
                                    <th>Receiver</th>
                                    <th>Type</th>
                                    <th>Packaging</th>
                                    <th>Payment</th>
                                    <th>Current Status</th>
                                    <th>Weight</th>
                                    <th>Dimensions</th>
                                    <th>Package Value</th>
                                    <th>Shipping Rate</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="shipmentsTableBody">
                                <tr>
                                    <td colspan="14" class="text-center">Loading shipments...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div id="shipmentsPagination" class="d-flex justify-content-center mt-3"></div>
                </div>
            </div>

            <div class="col-12 col-lg-3">
                <div class="right-block left-menu menu-with-title mt60 mb15">
                    <h4 class="title-with-bg">Quick Links</h4>
                    <ul>
                        <li class="active"><a asp-controller="Shipments" asp-action="List" title="Shipment history">Shipment History</a></li>
                        <li><a asp-controller="Shipments" asp-action="CreateShipment" title="Create shipment">Create Shipment</a></li>
                    </ul>
                </div>
                <a asp-controller="Shipments" asp-action="CreateShipment" class="order-list-button">Create New Shipment</a>
            </div>
        </div>
    </div>
</div>
<!-- Shipment History end -->

@section Scripts
{
    <script src="~/Modules/AppHelper.js"></script>
    <script src="~/Modules/ApiClient.js"></script>
    <script src="~/Modules/ShipmentsService.js" asp-append-version="true"></script>
    <script src="~/Modules/shipments-list.js" asp-append-version="true"></script>
}
