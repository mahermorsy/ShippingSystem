@model List<DtoShipment>
<!-- Breadcroumbs start -->
<div class="wshipping-content-block wshipping-breadcroumb inner-bg-1 shipment-history-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-lg-7">
                <span class="shipment-page-kicker">Customer workspace</span>
                <h1>Shipment History</h1>
                <div class="shipment-breadcrumb">
                    <a asp-controller="Home" asp-action="Index" title="Home">Home</a> / Shipment History
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="shipment-hero-note">
                    <i class="fa fa-shipping-fast"></i>
                    <h4>
                        Track every order from pickup to delivery with a cleaner operational view.
                    </h4>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcroumbs end -->

<!-- Shipment History start -->
<div class="wshipping-content-block shipment-history-page">
    <div class="container">
        <div class="row">
            <div class="col-12 col-lg-9">
                <div class="order-list shipment-history-card">
                    <div class="shipment-history-head">
                        <div>
                            <span class="shipment-page-kicker">Shipments</span>
                            <h3>Your Shipment History</h3>
                        </div>
                        <a asp-controller="Shipments" asp-action="CreateShipment" class="shipment-head-action">
                            <i class="fa fa-plus"></i> New Shipment
                        </a>
                    </div>
                    <div class="table-responsive shipment-history-table-wrap">
                        <table class="table table-bordered table-hover text-center align-middle shipment-history-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Tracking</th>
                                    <th>Shipping Date</th>
                                    <th>Delivery Date</th>
                                    <th>Sender</th>
                                    <th>Receiver</th>
                                    <th>Type</th>
                                    <th>Packaging</th>
                                    <th>Payment</th>
                                    <th>Current Status</th>
                                    <th>Weight</th>
                                    <th>Dimensions</th>
                                    <th>Package Value</th>
                                    <th>Shipping Rate</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="shipmentsTableBody">
                                <tr>
                                    <td colspan="15" class="text-center">Loading shipments...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div id="shipmentsPagination" class="d-flex justify-content-center mt-3"></div>
                </div>
            </div>

            <div class="col-12 col-lg-3">
                <div class="right-block left-menu menu-with-title mt60 mb15 shipment-side-card">
                    <h4 class="title-with-bg">Quick Links</h4>
                    <ul>
                        <li class="active"><a asp-controller="Shipments" asp-action="List" title="Shipment history">Shipment History</a></li>
                        <li><a asp-controller="Shipments" asp-action="CreateShipment" title="Create shipment">Create Shipment</a></li>
                    </ul>
                </div>
                <div class="shipment-side-summary">
                    <i class="fa fa-route"></i>
                    <strong>Need another delivery?</strong>
                    <span>Create a new shipment and follow it from here.</span>
                </div>
                <a asp-controller="Shipments" asp-action="CreateShipment" class="order-list-button shipment-create-button">Create New Shipment</a>
            </div>
        </div>
    </div>
</div>
<!-- Shipment History end -->

@section Scripts
{
    <script src="~/Modules/AppHelper.js"></script>
    <script src="~/Modules/ApiClient.js"></script>
    <script src="~/Modules/ShipmentsService.js" asp-append-version="true"></script>
    <script src="~/Modules/shipments-list.js" asp-append-version="true"></script>
}
