@model DTOLoginUser
  
<!-- Breadcroumbs start -->
<div class="wshipping-content-block wshipping-breadcroumb inner-bg-1 auth-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-lg-7">
                <span class="shipment-page-kicker">Secure access</span>
                <h1>Customer Login</h1>
                <div class="shipment-breadcrumb">
                    <a asp-controller="Home" asp-action="Index" title="Home">Home</a> / Customer Login
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="shipment-hero-note">
                    <i class="fa fa-lock"></i>
                    <h4>Sign in to manage shipments, review delivery progress, and keep customer details up to date.</h4>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcroumbs end -->
<!-- Customer login Start -->
<div class="wshipping-content-block auth-page">
    <div class="container">
        <div class="customer-login auth-card">
            <div class="row no-gutters">
                <div class="col-12 col-md-6 col-lg-5">
                    <div class="customer-login-left">
                        <div class="login-icon"><i class="fa fa-lock"></i></div>
                        <span class="auth-eyebrow">Welcome back</span>
                        <h4>Manage shipments with confidence</h4>
                        <p>Access your shipment history, create new deliveries, and review status updates from one account.</p>
                        <a asp-controller="Account" asp-action="Register" class="auth-secondary-link">@Lables.Registration</a>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-7">
                    <div class="customer-login-block">
                        <h2>Login To Your Account</h2>
                        <p class="auth-form-note">Use your account credentials to continue.</p>
                        <form asp-controller="Account" asp-action="Login" method="post">
                        
                            <div class="form-group">
                                <label>@Lables.Email</label>
                                <input type="text" asp-for="UserName" class="form-control" placeholder="@Lables.Enterusername" />
                                <span asp-validation-for="UserName" class="text-danger"></span> 
                            </div>
                            <div class="form-group">
                                <label>@Lables.Password</label>
                                <input asp-for="Password"
                                       type="password" class="form-control" placeholder="@Lables.EnterPassword" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="checkbox auth-options">
                                <span>
                                    <input type="checkbox" name="remember" id="remember" class="css-checkbox" />
                                    <label for="remember" class="css-label">@Lables.RememberMe</label>
                                </span>
                                <a href="#" title="" class="forgot-pass">@Lables.ForgotPassword</a>
                            </div>
                            <button type="submit" class="btn btn-submit">@Lables.Login</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
