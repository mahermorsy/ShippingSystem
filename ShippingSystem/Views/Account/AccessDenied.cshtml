@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Access Denied</title>

    <link rel="stylesheet" href="~/Admin/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/Admin/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/Admin/css/demo_2/style.css">
    <link rel="shortcut icon" href="~/Admin/images/favicon.png" />
</head>

<body>
    <div class="container-scroller">
        <div class="container-fluid page-body-wrapper full-page-wrapper">
            <div class="content-wrapper d-flex align-items-center text-center error-page bg-danger">
                <div class="row flex-grow">
                    <div class="col-lg-7 mx-auto text-white">

                        <div class="row align-items-center d-flex flex-row">

                            <!-- الرقم -->
                            <div class="col-lg-6 text-lg-right pr-lg-4">
                                <h1 class="display-1 mb-0">403</h1>
                            </div>

                            <!-- الرسالة -->
                            <div class="col-lg-6 error-page-divider text-lg-left pl-lg-4">
                                <h2>@Messages.AccessDenied</h2>
                                <h3 class="font-weight-light">
                                    @Messages.AccessDeniedMessage.
                                </h3>
                            </div>

                        </div>

                        <!-- زر الرجوع -->
                        <div class="row mt-5">
                            <div class="col-12 text-center mt-xl-2">
                                <a class="btn btn-light btn-rounded font-weight-bold"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Back to Login
                                </a>
                            </div>
                        </div>

                        <!-- footer -->
                        <div class="row mt-5">
                            <div class="col-12 mt-xl-2">
                                <p class="text-white font-weight-medium text-center">
                                    Access restricted © 2026
                                </p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/Admin/vendors/js/vendor.bundle.base.js"></script>
    <script src="~/Admin/js/off-canvas.js"></script>
    <script src="~/Admin/js/hoverable-collapse.js"></script>
    <script src="~/Admin/js/misc.js"></script>
    <script src="~/Admin/js/settings.js"></script>
    <script src="~/Admin/js/todolist.js"></script>
    <script src="~/Admin/js/jquery.cookie.js"></script>
</body>
</html>