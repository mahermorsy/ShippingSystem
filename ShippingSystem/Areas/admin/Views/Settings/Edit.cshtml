@model DtoSetting

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">@Lables.Settings</h3>
    </div>

    <div class="row">
        <div class="col-md-8 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">

                    <h4 class="card-title">@Lables.Settings</h4>

                    <form method="post"
                          asp-area="admin"
                          asp-controller="Settings"
                          asp-action="Save">

                        <input asp-for="Id" type="hidden" />

                        <!-- KiloMeter -->
                        <div class="form-group">
                            <label>@Lables.KiloMeterRate</label>
                            <input asp-for="KiloMeterRate"
                                   type="number"
                                   step="0.01"
                                   class="form-control"
                                   placeholder="@Lables.KiloMeterRate" />
                            <span asp-validation-for="KiloMeterRate" class="text-danger"></span>
                        </div>

                        <!-- Kilogram -->
                        <div class="form-group">
                            <label>@Lables.KilooGramRate</label>
                            <input asp-for="KilooGramRate"
                                   type="number"
                                   step="0.01"
                                   class="form-control"
                                   placeholder="@Lables.KilooGramRate" />
                            <span asp-validation-for="KilooGramRate" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-gradient-primary me-2">
                            @Actions.Save
                        </button>

                        <a asp-area="admin"
                           asp-controller="Settings"
                           asp-action="Index"
                           class="btn btn-light">
                            @Actions.Cancel
                        </a>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}