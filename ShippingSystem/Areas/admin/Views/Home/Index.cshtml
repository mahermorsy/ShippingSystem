
<div class="content-wrapper admin-dashboard">
    <div class="page-header admin-page-header">
        <div>
            <p class="page-kicker">Operations overview</p>
            <h3 class="page-title">
                <span class="page-title-icon text-white me-2">
                    <i class="mdi mdi-view-dashboard-outline"></i>
                </span>
                Dashboard
            </h3>
        </div>
        <nav aria-label="breadcrumb">
            <ul class="breadcrumb">
                <li class="breadcrumb-item active" aria-current="page">
                    Live admin workspace <i class="mdi mdi-pulse icon-sm text-success align-middle"></i>
                </li>
            </ul>
        </nav>
    </div>

    <div class="row">
        <div class="col-xl-3 col-md-6 stretch-card grid-margin">
            <div class="card metric-card metric-card-primary">
                <div class="card-body">
                    <div class="metric-icon"><i class="mdi mdi-package-variant-closed"></i></div>
                    <p class="metric-label">Total Shipments</p>
                    <h2>1,248</h2>
                    <span class="metric-note positive">+12% this month</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 stretch-card grid-margin">
            <div class="card metric-card metric-card-info">
                <div class="card-body">
                    <div class="metric-icon"><i class="mdi mdi-truck-fast-outline"></i></div>
                    <p class="metric-label">In Transit</p>
                    <h2>327</h2>
                    <span class="metric-note">42 need review</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 stretch-card grid-margin">
            <div class="card metric-card metric-card-success">
                <div class="card-body">
                    <div class="metric-icon"><i class="mdi mdi-check-decagram-outline"></i></div>
                    <p class="metric-label">Delivered</p>
                    <h2>861</h2>
                    <span class="metric-note positive">96% success rate</span>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 stretch-card grid-margin">
            <div class="card metric-card metric-card-warning">
                <div class="card-body">
                    <div class="metric-icon"><i class="mdi mdi-clock-alert-outline"></i></div>
                    <p class="metric-label">Pending</p>
                    <h2>60</h2>
                    <span class="metric-note warning">14 delayed</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 grid-margin stretch-card">
            <div class="card dashboard-panel">
                <div class="card-body">
                    <div class="panel-heading">
                        <div>
                            <p class="panel-eyebrow">Monthly volume</p>
                            <h4 class="card-title">Shipment Flow</h4>
                        </div>
                        <div id="visit-sale-chart-legend-dark" class="rounded-legend legend-horizontal legend-top-right"></div>
                    </div>
                    <canvas id="visit-sale-chart-dark" class="mt-4"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4 grid-margin stretch-card">
            <div class="card dashboard-panel">
                <div class="card-body">
                    <div class="panel-heading">
                        <div>
                            <p class="panel-eyebrow">Shipment mix</p>
                            <h4 class="card-title">Traffic Sources</h4>
                        </div>
                    </div>
                    <canvas id="traffic-chart"></canvas>
                    <div id="traffic-chart-legend" class="rounded-legend legend-vertical legend-bottom-left pt-4"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7 grid-margin stretch-card">
            <div class="card dashboard-panel">
                <div class="card-body">
                    <div class="panel-heading">
                        <div>
                            <p class="panel-eyebrow">Today</p>
                            <h4 class="card-title">Operational Priorities</h4>
                        </div>
                        <a asp-area="admin" asp-controller="Shipment" asp-action="Index" class="btn btn-outline-info btn-sm">View all</a>
                    </div>
                    <div class="ops-list">
                        <div class="ops-item">
                            <span class="ops-status is-active"></span>
                            <div>
                                <strong>Approve new shipment requests</strong>
                                <small>12 shipments are waiting for the next workflow step.</small>
                            </div>
                            <span class="ops-count">12</span>
                        </div>
                        <div class="ops-item">
                            <span class="ops-status is-warning"></span>
                            <div>
                                <strong>Review delayed deliveries</strong>
                                <small>Focus on shipments crossing their expected delivery date.</small>
                            </div>
                            <span class="ops-count">14</span>
                        </div>
                        <div class="ops-item">
                            <span class="ops-status is-success"></span>
                            <div>
                                <strong>Confirm delivered packages</strong>
                                <small>Close completed shipments and update customer visibility.</small>
                            </div>
                            <span class="ops-count">38</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5 grid-margin stretch-card">
            <div class="card dashboard-panel">
                <div class="card-body p-0">
                    <div id="inline-datepicker" class="datepicker datepicker-custom"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- content-wrapper ends -->
