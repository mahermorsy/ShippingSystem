@model DtoSubscriptionPackage

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">@Lables.SubscriptionPackage</h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                @* <li class="breadcrumb-item"><a href="#">@Actions.Update</a></li> *@
                <li class="breadcrumb-item active" aria-current="page"></li>
            </ol>
        </nav>
    </div>
    <div class="row">
        <div class="col-md-8 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    @{
                        if (Model.Id == Guid.Empty)
                        {
                            <h4 class="card-title">@Actions.AddNew</h4>
                
                        }
                        else
                        {
                            <h4 class="card-title">@Actions.Update</h4>
           
                        }
                    }
                   
                    <p class="card-description"></p>
                    <form class="forms-sample" method="post" enctype="multipart/form-data"
                          asp-area="admin" asp-controller="SubscriptionPackages" asp-action="Save" role="form">

                        <input asp-for="Id" type="hidden" />

                        <div class="form-group">
                            <label for="exampleInputUsername1">@Lables.PackageName</label>
                            <input asp-for="PackageName" type="text" class="form-control" placeholder="@Lables.NameAr">
                            <span asp-validation-for="PackageName" class="text-danger"></span>
                        </div>

                         <div class="form-group">
                            <label for="exampleInputUsername1">@Lables.ShippimentCount</label>
                            <input asp-for="ShippimentCount" type="number" class="form-control" placeholder="@Lables.NameEn">
                            <span asp-validation-for="ShippimentCount" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label for="exampleInputUsername1">@Lables.NumberOfKiloMeters</label>
                            <input asp-for="NumberOfKiloMeters" type="number" class="form-control" placeholder="@Lables.NameAr">
                            <span asp-validation-for="NumberOfKiloMeters" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label for="exampleInputUsername1">@Lables.ShippimentCount</label>
                            <input asp-for="TotalWeight" type="number" class="form-control" placeholder="@Lables.TotalWeight">
                            <span asp-validation-for="TotalWeight" class="text-danger"></span>
                        </div>

                        <button type="submit" formmethod="post" class="btn btn-gradient-primary me-2">@Actions.Save</button>
                        <button class="btn btn-light">@Actions.Cancel</button>
                    </form>
                </div>
            </div>
        </div>

      @*   <div class="col-md-4 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <span id="tbImgName"></span>
                    <div id="tbImgSrc">
                        <img src="/Uploads/Categories/@Model.ImageName" style="width:95%; height300px;" />
                    </div>
                </div>
            </div>
        </div> *@
    </div>
</div>

