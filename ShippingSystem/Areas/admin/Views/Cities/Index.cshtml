
@model List<DtoCity>

@section Styles
{
    <link href="~/admin/vendors/datatables.net-bs4/datatables.bootstrap4.css" rel="stylesheet" />
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">@Lables.Cities</h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb"></ol>
        </nav>

        <a asp-area="admin"
           asp-controller="Cities"
           asp-action="AddNew"
           class="btn btn-primary btn-fw">
            <i class="mdi mdi-plus"></i> @Actions.AddNew
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <h4 class="card-title">@Lables.Cities</h4>

            <div class="row">
                <div class="col-12">
                    <table id="order-listing" class="table">
                        <thead>
                            <tr>
                                <th>@Lables.NameEn</th>
                                <th>@Lables.NameAr</th>
                                <th>@Lables.Country</th>
                                <th>@Lables.Status</th>
                                <th>@Lables.Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var carrier in Model)
                            {
                                <tr>
                                    <td>@carrier.CityEname</td>
                                    <td>@carrier.CityAname</td>
                                    <td>@carrier.Country?.CountryEname</td>
                                    <td>@carrier.CurrentState</td>
                                    <td>
                                        <a asp-area="admin"
                                           asp-controller="Cities"
                                           asp-action="Edit"
                                           asp-route-CityId="@carrier.Id"
                                           class="btn btn-info btn-fw">
                                            @Actions.Edit
                                        </a>

                                        <button type="button"
                                                class="btn btn-danger btn-fw btn-delete"
                                                data-id="@carrier.Id">
                                            @Actions.Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/admin/vendors/datatables.net/jquery.datatables.js"></script>
    <script src="~/admin/vendors/datatables.net-bs4/datatables.bootstrap4.js"></script>
    <script src="~/admin/js/data-table.js"></script>

    @if (TempData["Messagetype"] != null)
    {
        <script>
            $(document).ready(function () {
                let message = parseInt('@TempData["Messagetype"]');

                switch (message) {
                    case 1:
                        appAlert.SUCCESS('@Messages.SaveSuccess', '@Messages.SaveSuccessMessage');
                        break;
                    case 2:
                        appAlert.ERROR('@Messages.SaveFailedTitle', '@Messages.SaveFailedMessage');
                        break;
                    case 3:
                        appAlert.SUCCESS('@Messages.UpdateSuccessTitle', '@Messages.UpdateSuccessMessage');
                        break;
                    case 4:
                        appAlert.ERROR('@Messages.UpdateFailedTitle', '@Messages.UpdateFailedMessage');
                        break;
                    case 5:
                        appAlert.SUCCESS('@Messages.DeleteSuccessTitle', '@Messages.DeleteSuccessMessage');
                        break;
                    case 6:
                        appAlert.ERROR('@Messages.DeleteFailedTitle', '@Messages.DeleteFailedMessage');
                        break;
                }
            });
        </script>
    }

    <script>
        $(document).ready(function () {
            $('#order-listing tbody').on('click', '.btn-delete', function (e) {
                e.preventDefault();

                var id = $(this).data('id');
                var deleteUrl = '@Url.Action("Delete", "Cities", new { area = "admin" })';

                appAlert.ConfirmDelete(function (result) {
                    if (result) {
                        window.location.href = deleteUrl + '?CityId=' + id;
                    }
                });
            });
        });
    </script>
}